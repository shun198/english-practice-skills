{
  "description": "Run the shared quality gate before Git commit, push, and GitHub PR commands.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.shun198-hooks/pre_git_quality_gate.py\"",
            "timeout": 1800,
            "statusMessage": "Running the Git quality gate"
          }
        ]
      }
    ]
  }
}
